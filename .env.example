# JARVIS Voice Shell — Public Configuration
# Copy to .env and fill in your values. Only the LLM provider key is required.
# Everything else has sensible defaults.

# ── LLM Provider (one of these is required) ──────────────────────────
# Provider order: GROQ → DEEPSEEK → OPENAI → LOCAL → HERMES
# First one with a key wins. Set only one to keep things simple.

# Groq — fastest, has free tier, ~150ms first token
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# DeepSeek — high quality, pay-per-token, ~500ms first token
# Get a key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# OpenAI — reliable, expensive, ~600ms first token
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Local (Ollama, vLLM, LM Studio — OpenAI-compatible)
# LOCAL_LLM_URL=http://localhost:11434/v1/chat/completions
# LOCAL_LLM_MODEL=qwen2.5:7b
# LOCAL_LLM_KEY=not-needed

# Hermes Agent or any other OpenAI-compatible local proxy
# HERMES_URL=http://127.0.0.1:6789/v1/chat/completions
# HERMES_API_KEY=***
# HERMES_MODEL=hermes-agent

# ── Voice System Prompt ──────────────────────────────────────────────
# Path to a file containing the voice system prompt.
# If unset, a generic JARVIS persona is used (under 100 tokens).
# If ~/.hermes/SOUL.md + ~/.hermes/USER.md exist, they are used (Hermes users).
# Keep it short — voice responses need concise context.
# JARVIS_SYSTEM_PROMPT_FILE=/path/to/your/voice-prompt.txt

# ── Filler Phrases ──────────────────────────────────────────────────
# Comma-separated list of "thinking" phrases that play immediately
# when the user finishes speaking, to mask LLM latency.
# Set to empty string to disable.
JARVIS_FILLER_PHRASES=One sec...,Checking...,On it...,Let me see...,Hmm,

# ── Whisper STT ──────────────────────────────────────────────────────
# URL of your local Whisper server (the bundled whisper-server/server.py)
WHISPER_URL=http://127.0.0.1:9001/v1/audio/transcriptions
# Model name. Options: "turbo" (default), "Systran/faster-distil-whisper-large-v3" (faster)
WHISPER_MODEL=turbo

# ── TTS ──────────────────────────────────────────────────────────────
JARVIS_TTS_ENGINE=edge
JARVIS_TTS_VOICE=en-GB-RyanNeural
JARVIS_TTS_RATE=+0%

# ── VAD ──────────────────────────────────────────────────────────────
JARVIS_VAD_ENERGY_THRESHOLD=300
JARVIS_VAD_END_SILENCE_MS=315
JARVIS_VAD_PRE_ROLL_MS=300
