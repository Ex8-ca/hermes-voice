# JARVIS Voice Shell Configuration
# Copy to .env and fill in values.

# ─── Hermes Gateway (runs on 192.168.1.3) ───────────────────────────────────
API_SERVER_KEY=chillygeek6789
API_SERVER_ENABLED=true
API_SERVER_HOST=192.168.1.3
API_SERVER_PORT=6789
HERMES_BRIDGE_URL=http://192.168.1.3:6789/v1/chat/completions
BRIDGE_MAX_TOKENS=512

# ─── TTS ─────────────────────────────────────────────────────────────────────
JARVIS_TTS_ENGINE=edge
JARVIS_TTS_VOICE=en-GB-RyanNeural
JARVIS_TTS_RATE=+0%

# ─── STT ─────────────────────────────────────────────────────────────────────
JARVIS_STT_ENGINE=whisper
JARVIS_STT_MODEL=tiny

# ─── VAD (always-on mode) ───────────────────────────────────────────────────
JARVIS_VAD_ENERGY_THRESHOLD=300
JARVIS_VAD_END_SILENCE_MS=700
JARVIS_VAD_PRE_ROLL_MS=300

# ─── Audio ───────────────────────────────────────────────────────────────────
# Leave None for auto-detect, or specify device index
# JARVIS_INPUT_DEVICE=2
# JARVIS_TTS_OUTPUT_DEVICE=3
